NEXT_PUBLIC_SUPABASE_URL=
# Use publishable key (Supabase dashboard) OR legacy anon key — one is required
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pooled connection for app runtime (port 6543, ?pgbouncer=true)
DATABASE_URL=
# Direct/session pooler for Prisma migrations (port 5432)
DIRECT_URL=
# Set to "true" when Twilio phone OTP is configured
NEXT_PUBLIC_AUTH_PHONE_ENABLED=false
