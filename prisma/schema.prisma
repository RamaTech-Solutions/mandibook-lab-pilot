generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MUNIM
}

enum PartyType {
  KISAN
  VYAPARI
}

enum BalanceType {
  RECEIVABLE
  PAYABLE
  NONE
}

enum CommodityUnit {
  KG
  QUINTAL
  BAG
}

enum EntryType {
  TRANSACTION
  PAYMENT
  CORRECTION
}

enum Direction {
  DEBIT
  CREDIT
}

enum PaymentMode {
  CASH
  UPI
  BANK
}

enum PaymentDirection {
  RECEIVED
  PAID
}

model Firm {
  id                    String   @id @default(cuid())
  name                  String
  mandiName             String   @map("mandi_name")
  ownerName             String   @map("owner_name")
  phone                 String
  address               String?
  defaultCommissionRate Decimal  @default(2) @map("default_commission_rate") @db.Decimal(5, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  profiles      Profile[]
  parties       Party[]
  commodities   Commodity[]
  transactions  Transaction[]
  ledgerEntries LedgerEntry[]
  payments      Payment[]
  auditLogs     AuditLog[]
  munimInvites  MunimInvite[]

  @@map("firms")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  firmId    String   @map("firm_id")
  fullName  String   @map("full_name")
  phone     String?
  role      Role     @default(MUNIM)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@map("profiles")
}

model MunimInvite {
  id        String   @id @default(cuid())
  firmId    String   @map("firm_id")
  fullName  String   @map("full_name")
  phone     String
  createdAt DateTime @default(now()) @map("created_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, phone])
  @@map("munim_invites")
}

model Party {
  id             String      @id @default(cuid())
  firmId         String      @map("firm_id")
  type           PartyType
  name           String
  phone          String?
  village        String?
  address        String?
  openingBalance Decimal     @default(0) @map("opening_balance") @db.Decimal(12, 2)
  balanceType    BalanceType @default(NONE) @map("balance_type")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  firm          Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
  payments      Payment[]
  farmerTxns    Transaction[] @relation("FarmerTransactions")
  traderTxns    Transaction[] @relation("TraderTransactions")

  @@index([firmId, type])
  @@map("parties")
}

model Commodity {
  id        String        @id @default(cuid())
  firmId    String        @map("firm_id")
  name      String
  unit      CommodityUnit @default(KG)
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  firm         Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([firmId, name])
  @@map("commodities")
}

model Transaction {
  id               String   @id @default(cuid())
  firmId           String   @map("firm_id")
  farmerId         String   @map("farmer_id")
  traderId         String   @map("trader_id")
  commodityId      String   @map("commodity_id")
  transactionDate  DateTime @map("transaction_date") @db.Date
  weight           Decimal  @db.Decimal(12, 3)
  rate             Decimal  @db.Decimal(12, 2)
  grossAmount      Decimal  @map("gross_amount") @db.Decimal(12, 2)
  commissionRate   Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(12, 2)
  deductions       Decimal  @default(0) @db.Decimal(12, 2)
  farmerPayable    Decimal  @map("farmer_payable") @db.Decimal(12, 2)
  traderReceivable Decimal  @map("trader_receivable") @db.Decimal(12, 2)
  notes            String?
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  firm       Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  farmer     Party         @relation("FarmerTransactions", fields: [farmerId], references: [id])
  trader     Party         @relation("TraderTransactions", fields: [traderId], references: [id])
  commodity  Commodity     @relation(fields: [commodityId], references: [id])
  entries    LedgerEntry[]

  @@index([firmId, transactionDate])
  @@map("transactions")
}

model LedgerEntry {
  id            String    @id @default(cuid())
  firmId        String    @map("firm_id")
  partyId       String    @map("party_id")
  transactionId String?   @map("transaction_id")
  paymentId     String?   @map("payment_id")
  entryDate     DateTime  @map("entry_date") @db.Date
  entryType     EntryType @map("entry_type")
  direction     Direction
  amount        Decimal   @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")

  firm        Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  party       Party        @relation(fields: [partyId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
  payment     Payment?     @relation(fields: [paymentId], references: [id])

  @@index([firmId, partyId, entryDate])
  @@map("ledger_entries")
}

model Payment {
  id          String           @id @default(cuid())
  firmId      String           @map("firm_id")
  partyId     String           @map("party_id")
  paymentDate DateTime         @map("payment_date") @db.Date
  amount      Decimal          @db.Decimal(12, 2)
  paymentMode PaymentMode      @map("payment_mode")
  direction   PaymentDirection
  notes       String?
  createdBy   String           @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")

  firm    Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  party   Party         @relation(fields: [partyId], references: [id])
  entries LedgerEntry[]

  @@index([firmId, paymentDate])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(cuid())
  firmId     String   @map("firm_id")
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, createdAt])
  @@map("audit_logs")
}
